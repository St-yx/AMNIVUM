# NUCLEUS configuration template.
# Copy to `.env` (gitignored) and adjust. All values below are working defaults;
# they match the in-code os.getenv() fallbacks. Empirical thresholds still need
# calibration against real interaction data.

# [Memoria-Chunking]
MEMORIA_MERGE_THRESHOLD=0.75            # core
MEMORIA_MAX_CHUNK_WORDS=50              # core
MEMORIA_MIN_CHUNK_WORDS=5               # core

# [Memoria-Core]
MEMORIA_NOVELTY_THRESHOLD=0.85          # core (importance gate)
MEMORIA_TOPIC_SWITCH_THRESHOLD=0.65     # core
MEMORIA_TOPIC_WINDOW_SIZE=5             # core
MEMORIA_GRAPH_PATH=data/cluster_graph.json   # core

# [Memoria-Retrieval]
MEMORIA_BUFFER_SIZE=20                  # retriever
MEMORIA_MID_CANDIDATES=20               # retriever
MEMORIA_MID_RECENT_TURNS=5              # retriever
MEMORIA_MID_NOVELTY_CANDIDATES=5        # retriever (k for novelty query in store_mid)
MEMORIA_LONG_CANDIDATES_PRIMARY=30      # retriever
MEMORIA_LONG_CANDIDATES_SIDE=10         # retriever

# [Memoria-Session-Log]
MEMORIA_SESSION_LOG_DIR=data/session_log  # core (append-only plaintext per session)

MEMORIA_CLUSTER_MATCH_THRESHOLD=0.45     # retriever

MEMORIA_TOPIC_DISTANCE_THRESHOLD=0.40   # retriever
MEMORIA_TOPIC_MAX=3                     # retriever

# [Memoria-Short]
MEMORIA_MID_CAP=5                       # short

MEMORIA_GUARANTEE_USER1=5               # short + retriever
MEMORIA_GUARANTEE_USER0=3               # short + retriever
MEMORIA_GUARANTEE_WORLD=2               # short + retriever

MEMORIA_SLOTS_TOPIC1=10                 # short
MEMORIA_SLOTS_SIDE=5                    # short

# [Ingenium-Interpreter]
INGENIUM_CLASSIFIER_THRESHOLD=0.3       # interpreter

# [Ingenium-Affect] (Update 1)
AFFECT_PATH=data/affect.json            # main (global_affect state file)

AFFECT_WEIGHT_AI=1.0                    # affect (knowledge_source user0)
AFFECT_WEIGHT_WORLD=0.5                 # affect (knowledge_source world)
AFFECT_WEIGHT_USER=0.25                 # affect (knowledge_source user1)

AFFECT_WEIGHT_TOPIC1=1.0                # affect (primary topic)
AFFECT_WEIGHT_TOPIC2=0.5                # affect (satellite)
AFFECT_WEIGHT_TOPIC3=0.25               # affect (satellite)

AFFECT_LEARNING_RATE=0.05               # affect (current_affect nudge)
ACCEPT_WEIGHT_GLOBAL=0.6                # affect (acceptance_tags)
ACCEPT_WEIGHT_TURN=0.4                  # affect (acceptance_tags)
DRIFT_HIGH=0.45                         # affect (CONFLICT threshold)

# [Models]
CLASSIFIER_MODEL=tabularisai/multilingual-emotion-classification

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# [Vectorstorage]
COLLECTION_LONG=memoria_long
COLLECTION_MID=memoria_mid

LOG_LEVEL=DEBUG

VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_IMAGE=qdrant/qdrant:latest
VECTOR_DB_VOLUME=./vector_storage:/qdrant/storage

VECTOR_SIZE=384
